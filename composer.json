{
    "name": "trafficdesign/laravel-smoke-test",
    "description": "Automatisierter Smoke-Test für Laravel-Anwendungen – testet alle parameterfreien GET-Routen auf 500er.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "trafficdesign"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Trafficdesign\\SmokeTest\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Trafficdesign\\SmokeTest\\SmokeTestServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
